# Variables de Entorno para EasyPanel
# Copia este archivo a .env y configura los valores según tu entorno

# API URL (si la app se conecta a un backend)
VITE_API_URL=https://api.tu-dominio.com

# Google Maps API Key (para el mapa en GeoIntelligence)
VITE_GOOGLE_MAPS_API_KEY=tu_api_key_aqui

# Leaflet Tile Layer URL (para el mapa)
VITE_LEAFLET_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Analytics (opcional)
VITE_GA_ID=G-XXXXXXXXXX

# Environment
VITE_ENV=production

# App Title
VITE_APP_TITLE=Vehicle Intelligence
